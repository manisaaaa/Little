<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Little ABRM Bakes | Tiny Bites, Big Happiness ✨</title>
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Dancing+Script:wght@400;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Quicksand', sans-serif;
            color: #5a3e2b;
            background-color: #fffaf5;
            line-height: 1.6;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #f9e4d4;
        }

        ::-webkit-scrollbar-thumb {
            background: #c29a7a;
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #a57b5e;
        }

        /* Header Section */
        header {
            background-color: #ffffff;
            box-shadow: 0 2px 20px rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 0.8rem 5%;
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo-container img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #f8d7b0;
        }

        .brand-text {
            font-family: 'Dancing Script', cursive;
            font-size: 1.8rem;
            font-weight: 700;
            color: #c27b4a;
            line-height: 1.2;
        }

        .brand-text span {
            font-family: 'Quicksand', sans-serif;
            font-size: 0.9rem;
            display: block;
            color: #a57b5e;
            letter-spacing: 1px;
            font-weight: 400;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        nav ul li a {
            text-decoration: none;
            color: #5a3e2b;
            font-weight: 500;
            font-size: 1rem;
            transition: color 0.3s ease;
            position: relative;
        }

        nav ul li a:hover {
            color: #c27b4a;
        }

        nav ul li a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background-color: #c27b4a;
            transition: width 0.3s ease;
        }

        nav ul li a:hover::after {
            width: 100%;
        }

        .header-icons {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

        .header-icons a {
            color: #5a3e2b;
            font-size: 1.2rem;
            transition: color 0.3s ease;
        }

        .header-icons a:hover {
            color: #c27b4a;
        }

        .mobile-menu {
            display: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: #5a3e2b;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #fff6ed 0%, #ffe6d5 100%);
            padding: 4rem 5%;
            min-height: calc(100vh - 80px);
            display: flex;
            align-items: center;
        }

        .hero-container {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .hero-content h5 {
            font-size: 1.1rem;
            color: #c27b4a;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 1rem;
        }

        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 700;
            color: #3d2b1c;
            line-height: 1.2;
            margin-bottom: 1.5rem;
        }

        .hero-content h1 span {
            font-family: 'Dancing Script', cursive;
            color: #c27b4a;
            display: block;
            font-size: 4rem;
        }

        .hero-content p {
            font-size: 1.1rem;
            color: #7b5f4b;
            margin-bottom: 2rem;
            max-width: 500px;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn-primary {
            background-color: #c27b4a;
            color: white;
            padding: 1rem 2.5rem;
            border: none;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            box-shadow: 0 4px 15px rgba(194, 123, 74, 0.3);
        }

        .btn-primary:hover {
            background-color: #a5673a;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(194, 123, 74, 0.4);
        }

        .btn-secondary {
            background-color: transparent;
            color: #5a3e2b;
            padding: 1rem 2.5rem;
            border: 2px solid #c27b4a;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-secondary:hover {
            background-color: #c27b4a;
            color: white;
            transform: translateY(-2px);
        }

        .hero-image {
            position: relative;
        }

        .hero-image img {
            width: 100%;
            height: auto;
            border-radius: 30px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }

        .hero-image:hover img {
            transform: scale(1.02);
        }

        .hero-image::before {
            content: '✨';
            position: absolute;
            top: -20px;
            right: -20px;
            font-size: 3rem;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        /* Features Section (Section 2) */
        .features {
            padding: 5rem 5%;
            background-color: #ffffff;
        }

        .section-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .section-header h2 {
            font-size: 2.5rem;
            color: #3d2b1c;
            margin-bottom: 1rem;
        }

        .section-header h2 span {
            font-family: 'Dancing Script', cursive;
            color: #c27b4a;
        }

        .section-header p {
            color: #7b5f4b;
            font-size: 1.1rem;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .feature-card {
            text-align: center;
            padding: 2rem;
            border-radius: 20px;
            background-color: #fffaf5;
            transition: all 0.3s ease;
            border: 1px solid #f8e0d0;
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(194, 123, 74, 0.1);
            border-color: #c27b4a;
        }

        .feature-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #f8d7b0, #f9e4d4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: #c27b4a;
        }

        .feature-card h3 {
            font-size: 1.3rem;
            margin-bottom: 0.8rem;
            color: #3d2b1c;
        }

        .feature-card p {
            color: #7b5f4b;
            font-size: 0.95rem;
        }

        /* Menu Section (Section 3) */
        .menu {
            padding: 5rem 5%;
            background: linear-gradient(135deg, #fff6ed 0%, #ffe6d5 100%);
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .menu-item {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }

        .menu-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(194, 123, 74, 0.15);
        }

        .menu-item-image {
            height: 200px;
            background: linear-gradient(135deg, #f8d7b0, #f9e4d4);
            position: relative;
            overflow: hidden;
        }

        .menu-item-image i {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3rem;
            color: #c27b4a;
            opacity: 0.5;
        }

        .menu-item-content {
            padding: 1.5rem;
        }

        .menu-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }

        .menu-item-header h3 {
            font-size: 1.3rem;
            color: #3d2b1c;
        }

        .menu-item-header .price {
            font-size: 1.3rem;
            font-weight: 700;
            color: #c27b4a;
        }

        .menu-item-desc {
            color: #7b5f4b;
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }

        .menu-item-tags {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .tag {
            background-color: #f9e4d4;
            color: #c27b4a;
            padding: 0.3rem 0.8rem;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        /* About Section (Section 4) */
        .about {
            padding: 5rem 5%;
            background-color: #ffffff;
        }

        .about-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .about-content h2 {
            font-size: 2.5rem;
            color: #3d2b1c;
            margin-bottom: 1rem;
        }

        .about-content h2 span {
            font-family: 'Dancing Script', cursive;
            color: #c27b4a;
        }

        .about-content p {
            color: #7b5f4b;
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
        }

        .about-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: 2rem;
        }

        .stat {
            text-align: center;
        }

        .stat h3 {
            font-size: 2rem;
            color: #c27b4a;
            margin-bottom: 0.3rem;
        }

        .stat p {
            font-size: 0.95rem;
            color: #7b5f4b;
            margin-bottom: 0;
        }

        .about-image {
            position: relative;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }

        .about-image img {
            width: 100%;
            height: auto;
            display: block;
            transition: transform 0.3s ease;
        }

        .about-image:hover img {
            transform: scale(1.05);
        }

        /* Testimonials Section (Section 5) */
        .testimonials {
            padding: 5rem 5%;
            background: linear-gradient(135deg, #fff6ed 0%, #ffe6d5 100%);
        }

        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }

        .testimonial-card {
            background: white;
            padding: 2rem;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            position: relative;
        }

        .testimonial-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(194, 123, 74, 0.1);
        }

        .testimonial-card i.fa-quote-left {
            color: #c27b4a;
            opacity: 0.2;
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .testimonial-text {
            font-size: 1rem;
            color: #5a3e2b;
            margin-bottom: 1.5rem;
            font-style: italic;
            line-height: 1.8;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .author-avatar {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #f8d7b0, #f9e4d4);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #c27b4a;
            font-weight: 700;
            font-size: 1.2rem;
        }

        .author-info h4 {
            font-size: 1.1rem;
            color: #3d2b1c;
            margin-bottom: 0.2rem;
        }

        .author-info p {
            font-size: 0.9rem;
            color: #7b5f4b;
        }

        .rating {
            color: #ffb800;
            margin-bottom: 1rem;
        }

        /* Footer */
        footer {
            background-color: #3d2b1c;
            color: #fffaf5;
            padding: 3rem 5% 1.5rem;
        }

        .footer-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .footer-content {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-bottom: 2rem;
        }

        .footer-col h3 {
            font-size: 1.2rem;
            margin-bottom: 1.5rem;
            position: relative;
        }

        .footer-col h3::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 40px;
            height: 2px;
            background-color: #c27b4a;
        }

        .footer-col p {
            color: #e6d5c5;
            margin-bottom: 0.8rem;
            font-size: 0.95rem;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col ul li {
            margin-bottom: 0.8rem;
        }

        .footer-col ul li a {
            color: #e6d5c5;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .footer-col ul li a:hover {
            color: #c27b4a;
            padding-left: 5px;
        }

        .social-links {
            display: flex;
            gap: 1rem;
            margin-top: 1rem;
        }

        .social-links a {
            color: #fffaf5;
            background-color: rgba(255,255,255,0.1);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .social-links a:hover {
            background-color: #c27b4a;
            transform: translateY(-3px);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(255,250,245,0.1);
            color: #e6d5c5;
            font-size: 0.9rem;
        }

        .footer-bottom span {
            color: #c27b4a;
            font-family: 'Dancing Script', cursive;
        }

        /* Responsive Design */
        @media (max-width: 1024px) {
            .hero-content h1 {
                font-size: 3rem;
            }
            .hero-content h1 span {
                font-size: 3.5rem;
            }
        }

        @media (max-width: 768px) {
            nav {
                display: none;
            }
            
            .mobile-menu {
                display: block;
            }
            
            .hero-container,
            .about-container {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            
            .hero-content {
                text-align: center;
            }
            
            .hero-content p {
                margin-left: auto;
                margin-right: auto;
            }
            
            .hero-buttons {
                justify-content: center;
            }
            
            .hero-image {
                order: -1;
            }
            
            .hero-content h1 {
                font-size: 2.5rem;
            }
            .hero-content h1 span {
                font-size: 3rem;
            }
            
            .about-stats {
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .brand-text {
                font-size: 1.4rem;
            }
            
            .hero-content h1 {
                font-size: 2rem;
            }
            .hero-content h1 span {
                font-size: 2.5rem;
            }
            
            .btn-primary,
            .btn-secondary {
                padding: 0.8rem 1.8rem;
                font-size: 0.9rem;
            }
            
            .features-grid,
            .menu-grid,
            .testimonials-grid {
                grid-template-columns: 1fr;
            }
            
            .about-stats {
                grid-template-columns: 1fr;
                gap: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Header Section -->
    <header>
        <div class="header-container">
            <div class="logo-container">
                <img src="https://i.ibb.co/tM15ngPb/Abrm.jpg" alt="Little ABRM Bakes Logo">
                <div class="brand-text">
                    Little ABRM Bakes
                    <span>Tiny Bites, Big Happiness ✨</span>
                </div>
            </div>
            <nav>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#features">Features</a></li>
                    <li><a href="#menu">Menu</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#testimonials">Reviews</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </nav>
            <div class="header-icons">
                <a href="#"><i class="fas fa-search"></i></a>
                <a href="#"><i class="fas fa-shopping-bag"></i></a>
                <a href="#"><i class="fas fa-user"></i></a>
            </div>
            <div class="mobile-menu">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </header>

    <!-- Hero Section (Section 1) -->
    <section class="hero" id="home">
        <div class="hero-container">
            <div class="hero-content">
                <h5>Welcome to Little ABRM Bakes</h5>
                <h1>
                    Tiny Bites,
                    <span>Big Happiness ✨</span>
                </h1>
                <p>Indulge in our handcrafted miniature treats made with love and the finest ingredients. Every bite brings a moment of pure joy!</p>
                <div class="hero-buttons">
                    <a href="#" class="btn-primary">Order Now <i class="fas fa-arrow-right"></i></a>
                    <a href="#" class="btn-secondary">View Menu</a>
                </div>
            </div>
            <div class="hero-image">
                <img src="https://i.ibb.co/MxWt8ZK3/bake-jpg.jpg" alt="Delicious baked treats from Little ABRM Bakes">
            </div>
        </div>
    </section>

    <!-- Features Section (Section 2) -->
    <section class="features" id="features">
        <div class="section-container">
            <div class="section-header">
                <h2>Why Choose <span>Little ABRM Bakes?</span></h2>
                <p>We bake with love and the finest ingredients to bring you happiness in every tiny bite</p>
            </div>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-leaf"></i>
                    </div>
                    <h3>Fresh Ingredients</h3>
                    <p>We use only the finest, locally-sourced ingredients in all our baked goods</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-heart"></i>
                    </div>
                    <h3>Made with Love</h3>
                    <p>Every treat is handcrafted with care and passion for baking</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-crown"></i>
                    </div>
                    <h3>Premium Quality</h3>
                    <p>Experience the finest miniature bakes in town</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-truck"></i>
                    </div>
                    <h3>Free Delivery</h3>
                    <p>Enjoy free delivery on orders above $25</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Menu Section (Section 3) -->
    <section class="menu" id="menu">
        <div class="section-container">
            <div class="section-header">
                <h2>Our <span>Signature Bites</span></h2>
                <p>Discover our most-loved miniature treats</p>
            </div>
            <div class="menu-grid">
                <div class="menu-item">
                    <div class="menu-item-image">
                        <i class="fas fa-cookie-bite"></i>
                    </div>
                    <div class="menu-item-content">
                        <div class="menu-item-header">
                            <h3>Mini Chocolate Chip Cookies</h3>
                            <span class="price">$8.99</span>
                        </div>
                        <p class="menu-item-desc">Bite-sized cookies loaded with premium chocolate chips</p>
                        <div class="menu-item-tags">
                            <span class="tag">Vegetarian</span>
                            <span class="tag">Popular</span>
                        </div>
                    </div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-image">
                        <i class="fas fa-cupcake"></i>
                    </div>
                    <div class="menu-item-content">
                        <div class="menu-item-header">
                            <h3>Assorted Mini Cupcakes</h3>
                            <span class="price">$12.99</span>
                        </div>
                        <p class="menu-item-desc">12 assorted flavors in perfect bite-size portions</p>
                        <div class="menu-item-tags">
                            <span class="tag">Vegetarian</span>
                            <span class="tag">Best Seller</span>
                        </div>
                    </div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-image">
                        <i class="fas fa-birthday-cake"></i>
                    </div>
                    <div class="menu-item-content">
                        <div class="menu-item-header">
                            <h3>Mini Cheesecake Bites</h3>
                            <span class="price">$14.99</span>
                        </div>
                        <p class="menu-item-desc">Creamy cheesecake bites with various toppings</p>
                        <div class="menu-item-tags">
                            <span class="tag">Gluten-Free</span>
                        </div>
                    </div>
                </div>
                <div class="menu-item">
                    <div class="menu-item-image">
                        <i class="fas fa-candy-cane"></i>
                    </div>
                    <div class="menu-item-content">
                        <div class="menu-item-header">
                            <h3>Macaron Minis</h3>
                            <span class="price">$16.99</span>
                        </div>
                        <p class="menu-item-desc">Delicate French macarons in 6 flavors</p>
                        <div class="menu-item-tags">
                            <span class="tag">Gluten-Free</span>
